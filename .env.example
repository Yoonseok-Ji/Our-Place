# PostgreSQL
POSTGRES_USER=ourplace
POSTGRES_PASSWORD=ourplace_secret
POSTGRES_DB=ourplace_db
DATABASE_URL=postgresql://ourplace:ourplace_secret@db:5432/ourplace_db

# JWT
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Kakao Maps API (발급: https://developers.kakao.com)
KAKAO_MAP_KEY=YOUR_KAKAO_MAP_KEY_HERE

# CORS — 프론트엔드 S3 정적 웹사이트 도메인
CORS_ORIGINS=http://duo-log-fe-449902674087.s3-website.ap-northeast-2.amazonaws.com

# AWS S3 — IAM Instance Role 사용 (액세스 키 불필요)
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=duo-log-imageserver-449902674087

# AWS SES — 이메일 인증 발송 (SES에서 인증된 이메일만 사용 가능)
SES_SENDER_EMAIL=noreply@yourdomain.com
EMAIL_FROM_NAME=우리들의 지도

# 소셜 로그인 — 백엔드 시크릿 (절대 프론트엔드에 노출 금지)
KAKAO_CLIENT_ID=        # 카카오 개발자콘솔 → REST API 키
KAKAO_CLIENT_SECRET=    # 카카오 개발자콘솔 → 보안 → Client Secret
NAVER_CLIENT_ID=        # 네이버 개발자 콘솔 → Client ID
NAVER_CLIENT_SECRET=    # 네이버 개발자 콘솔 → Client Secret
GOOGLE_CLIENT_ID=       # Google Cloud Console → OAuth 2.0 클라이언트 ID
GOOGLE_CLIENT_SECRET=   # Google Cloud Console → OAuth 2.0 클라이언트 보안 비밀

# 프론트엔드 배포 URL (OAuth redirect_uri 검증용)
FRONTEND_URL=http://localhost:5173
