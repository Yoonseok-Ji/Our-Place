# PostgreSQL
POSTGRES_USER=ourplace
POSTGRES_PASSWORD=ourplace_secret
POSTGRES_DB=ourplace_db
DATABASE_URL=postgresql://ourplace:ourplace_secret@db:5432/ourplace_db

# JWT
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Kakao Maps API (발급: https://developers.kakao.com)
KAKAO_MAP_KEY=YOUR_KAKAO_MAP_KEY_HERE
