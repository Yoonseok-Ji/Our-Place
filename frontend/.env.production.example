# 프로덕션 빌드 시 사용하는 환경변수
# 이 파일을 .env.production 으로 복사하고 실제 값으로 채우세요

# FastAPI 백엔드 공개 URL (EC2 퍼블릭 IP 또는 도메인)
# 끝에 슬래시(/) 없이 입력
VITE_API_BASE_URL=http://YOUR_EC2_IP:8000/api
VITE_BACKEND_URL=http://YOUR_EC2_IP:8000

# 카카오맵 API 키
VITE_KAKAO_MAP_KEY=100542b77023a9ade8b363cc716f745b

# 소셜 로그인 — 공개 Client ID (프론트에서 OAuth URL 생성 용, 시크릿 아님)
# 카카오: 개발자 콘솔 → REST API 키
VITE_KAKAO_OAUTH_CLIENT_ID=
# 네이버: 개발자 콘솔 → Client ID
VITE_NAVER_CLIENT_ID=
# 구글: HTTPS 도메인이 있을 때만 (S3 HTTP 환경에서는 동작 안 함)
# VITE_GOOGLE_CLIENT_ID=
